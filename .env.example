# Supabase — connection strings (obter em app.supabase.com > Project Settings > Database)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Supabase — chaves da app (obter em Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# APIs externas — só servidor, NUNCA prefixo NEXT_PUBLIC_
FINNHUB_API_KEY=
POLYGON_API_KEY=
GEMINI_API_KEY=

# Modelo Gemini Flash — confirmar nome disponível em aistudio.google.com/models
# Exemplo: gemini-2.0-flash, gemini-2.5-flash — não hardcoded no código
GEMINI_MODEL=

# i18n
NEXT_PUBLIC_DEFAULT_LOCALE=pt
