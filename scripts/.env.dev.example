# BD de DESENVOLVIMENTO — projeto Supabase separado do de produção.
# Copia este ficheiro para .env.dev (na raiz do projeto, não nesta pasta)
# e preenche com as credenciais do projeto de dev.
#
# NUNCA uses as credenciais de produção (.env.local) aqui.
# Os scripts de ingestão recusam correr sem este ficheiro.

# Supabase DEV — connection string direta (não o pooler)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# APIs externas
FINNHUB_API_KEY=
POLYGON_API_KEY=
